\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START
\loggingoutput

\ExplSyntaxOn

% Test 1 -- 2: Function \__xeCJK_check_num_range:nnNN with #1 or #2 blank

\TEST { Left ~ empty: ~  0x0042 ~ as ~ start ~ and ~ end }
  {
    \int_zero:N \l_tmpa_int
    \int_zero:N \l_tmpb_int
    \__xeCJK_check_num_range:nnNN { } { "0042 } \l_tmpa_int \l_tmpb_int
    \TYPE { From ~ \int_use:N \l_tmpa_int \space to ~ \int_use:N \l_tmpb_int }
  }

\TEST { Right ~ empty: ~ 0x0041 ~ as ~ start ~ and ~ end }
  {
    \int_zero:N \l_tmpa_int
    \int_zero:N \l_tmpb_int
    \__xeCJK_check_num_range:nnNN { "0041 } { } \l_tmpa_int \l_tmpb_int
    \TYPE { From ~ \int_use:N \l_tmpa_int \space to ~ \int_use:N \l_tmpb_int }
  }

% Test 3: Advanced interface \xeCJKDeclareCharClass

\TEST { xeCJKDeclareCharClass ~ (one-sided ~ empty ~ ranges) }
  {
    \xeCJKDeclareCharClass { CJK } { -> "0041 , "0042 -> }
    \TYPE
      {
        Class ~ A ~ (0x0041): ~ \int_use:N \tex_XeTeXcharclass:D `A , ~
        Class ~ B ~ (0x0042): ~ \int_use:N \tex_XeTeXcharclass:D `B , ~
      }
    \TYPE
      { Target ~ CJK ~ Class: ~ \int_use:c { \__xeCJK_class_csname:n { CJK } } }
  }

\ExplSyntaxOff

\END
