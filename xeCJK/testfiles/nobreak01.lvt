\START

\loggingoutput

\TEST{xeCJKnobreak prevents break after punct}{
  \hsize=6em
  字字字字字，\xeCJKnobreak 不断行。字字字字字字字字
  \clearpage
}

\TEST{without xeCJKnobreak allows break}{
  \hsize=6em
  字字字字字，允许断。字字字字字字字字
  \clearpage
}

\END

