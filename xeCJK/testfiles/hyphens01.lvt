\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\setbox0=\hbox{字～字}
\setbox1=\hbox{字—字}

\edef\widthTilde{\the\wd0}
\edef\widthDash{\the\wd1}

\TEST{fullwidth~tilde~same~width~as~em~dash}{
  \TYPE{tilde~=~\widthTilde}
  \TYPE{dash~~=~\widthDash}
  \ifdim\dimexpr\wd0-\wd1\relax<0.1pt\relax
    \ifdim\dimexpr\wd1-\wd0\relax<0.1pt\relax
      \TYPE{PASS}
    \else
      \TYPE{FAIL:~widths~differ~by~more~than~0.1pt}
    \fi
  \else
    \TYPE{FAIL:~widths~differ~by~more~than~0.1pt}
  \fi
}

\setbox2=\hbox{123～234}
\setbox3=\hbox{123—234}

\edef\widthNumTilde{\the\wd2}
\edef\widthNumDash{\the\wd3}

\TEST{number~tilde~number~same~width~as~number~dash~number}{
  \TYPE{num-tilde~=~\widthNumTilde}
  \TYPE{num-dash~~=~\widthNumDash}
  \ifdim\dimexpr\wd2-\wd3\relax<0.1pt\relax
    \ifdim\dimexpr\wd3-\wd2\relax<0.1pt\relax
      \TYPE{PASS}
    \else
      \TYPE{FAIL:~widths~differ~by~more~than~0.1pt}
    \fi
  \else
    \TYPE{FAIL:~widths~differ~by~more~than~0.1pt}
  \fi
}

\END

\end{document}
