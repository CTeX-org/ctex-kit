\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{CJKspace=false (default): space between CJK ignored}{
  \setbox0=\hbox{Õ¡ùÕ¡ù}
  \setbox1=\hbox{Õ¡ù Õ¡ù}
  \ifdim\wd0=\wd1
    \TYPE{PASS: space ignored}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

\TEST{CJKspace=true: space between CJK preserved}{
  \xeCJKsetup{CJKspace=true}
  \setbox0=\hbox{Õ¡ùÕ¡ù}
  \setbox1=\hbox{Õ¡ù Õ¡ù}
  \ifdim\wd0=\wd1
    \TYPE{FAIL: widths equal, space not preserved}
  \else
    \TYPE{PASS: \the\wd0\space vs \the\wd1}
  \fi
  \xeCJKsetup{CJKspace=false}
}

\TEST{CJKspace switch takes effect immediately}{
  \setbox0=\hbox{Õ¡ù Õ¡ù}
  \xeCJKsetup{CJKspace=true}
  \setbox1=\hbox{Õ¡ù Õ¡ù}
  \xeCJKsetup{CJKspace=false}
  \setbox2=\hbox{Õ¡ù Õ¡ù}
  \TYPE{nospace: \the\wd0}
  \TYPE{space: \the\wd1}
  \TYPE{nospace-again: \the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS: restored}
  \else
    \TYPE{FAIL: not restored}
  \fi
}

\END

\end{document}
