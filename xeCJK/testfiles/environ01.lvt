\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{CJK in minipage}{
  \setbox0=\vbox{\hsize=200pt
    \begin{minipage}{200pt}
    字字字字字字字字字字字字字字字字字字字字。
    \end{minipage}
  }
  \TYPE{minipage-height: \the\ht0}
}

\TEST{CJK in footnote}{
  \setbox0=\hbox{字字字\footnote{注释文本。}}
  \TYPE{footnote-text-width: \the\wd0}
}

\TEST{CJK in parbox}{
  \setbox0=\hbox{\parbox{100pt}{字字字字字字字字字字。}}
  \TYPE{parbox-width: \the\wd0}
}

\TEST{CJK across group boundary}{
  \setbox0=\hbox{字{\bfseries 字}字}
  \setbox2=\hbox{字字字}
  \TYPE{with-group: \the\wd0}
  \TYPE{without-group: \the\wd2}
}

\END

\end{document}
