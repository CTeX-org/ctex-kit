  \BoundaryIntrinsicDelta=\dimexpr
    \wd\BoundaryCandidate-\wd\BoundaryOracle\relax
  \BoundaryReset\setbox\BoundaryCandidateContext=\hbox{中\verb|中文|文}
  \BoundaryAssertIdle{verb-CJKspace}{00}
  \BoundaryReset\setbox\BoundaryOracleContext=\hbox{中中文文}
  \BoundaryReport{verb-CJKspace}{00}
  \BoundaryReset\setbox\BoundaryCandidateContext=\hbox{中 \verb|中文|文}
  \BoundaryAssertIdle{verb-CJKspace}{10}
  \BoundaryReset\setbox\BoundaryOracleContext=\hbox{中 中文文}
  \BoundaryReport{verb-CJKspace}{10}
  \BoundaryReset\setbox\BoundaryCandidateContext=\hbox{中\verb|中文| 文}
  \BoundaryAssertIdle{verb-CJKspace}{01}
  \BoundaryReset\setbox\BoundaryOracleContext=\hbox{中中文 文}
  \BoundaryReport{verb-CJKspace}{01}
  \BoundaryReset\setbox\BoundaryCandidateContext=\hbox{中 \verb|中文| 文}
  \BoundaryAssertIdle{verb-CJKspace}{11}
  \BoundaryReset\setbox\BoundaryOracleContext=\hbox{中 中文 文}
  \BoundaryReport{verb-CJKspace}{11}
\endgroup

\TYPE{command boundary checks: \the\BoundaryChecks}
\TYPE{command boundary failures: \the\BoundaryFailures}

\END

