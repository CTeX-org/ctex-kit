  \setbox\BoundaryNullBox\null
  Alpha%
}
\newcommand\BoundaryMeasuredWestern{%
  \sbox\BoundaryScratchBox{中文}%
  Alpha%
}
\newcommand\BoundaryDeepBoxes[1]{%
  \mbox{\mbox{\mbox{\mbox{\mbox{\mbox{%
    \mbox{\mbox{\mbox{\mbox{\mbox{\mbox{#1}}}}}}%
  }}}}}}%
}

