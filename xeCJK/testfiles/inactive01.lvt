\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{makexeCJKinactive disables interchar}{
  \setbox0=\hbox{Õ¡ùAÕ¡ù}
  \setbox1=\hbox{{\makexeCJKinactive Õ¡ùAÕ¡ù}}
  \TYPE{active: \the\wd0}
  \TYPE{inactive: \the\wd1}
}

\TEST{makexeCJKactive restores interchar}{
  \setbox0=\hbox{Õ¡ùAÕ¡ù}
  \setbox1=\hbox{{\makexeCJKinactive\makexeCJKactive Õ¡ùAÕ¡ù}}
  \ifdim\wd0=\wd1
    \TYPE{PASS: restored}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

\TEST{inactive scope limited to group}{
  \setbox0=\hbox{Õ¡ùAÕ¡ù}
  {\makexeCJKinactive}
  \setbox1=\hbox{Õ¡ùAÕ¡ù}
  \ifdim\wd0=\wd1
    \TYPE{PASS: group scoped}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

\END

\end{document}
