\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\usepackage{url}
\setCJKmainfont{FandolSong-Regular.otf}

\newcommand\AssertUrlBoundaryEquivalent[4]{%
  \dimen0=\wd#1
  \advance\dimen0 by -\wd#2
  \advance\dimen0 by -\wd#3
  \advance\dimen0 by \wd#4
  \ifdim\dimen0<0pt
    \dimen0=-\dimen0
  \fi
  \ifdim\dimen0<0.01pt
    \TYPE{PASS: boundary delta \the\dimen0}%
  \else
    \TYPE{FAIL: boundary delta \the\dimen0}%
  \fi
}

\begin{document}

\START

% #880: CJK followed by \url should have ecglue inserted on the left side.
% Without the fix, the boundary marker kern is shadowed by the math node,
% so the left ecglue is lost and the box becomes ~3.33pt narrower.

\TEST{ecglue between CJK and url (880)}{
  \setbox0=\hbox{测\url{X}无}
  \setbox1=\hbox{测X无}
  \setbox2=\hbox{\url{X}}
  \setbox3=\hbox{X}
  \AssertUrlBoundaryEquivalent{0}{1}{2}{3}
}

\TEST{source spaces around url match direct input (880)}{
  \setbox0=\hbox{测试 \url{X} 无}
  \setbox1=\hbox{测试 X 无}
  \setbox2=\hbox{\url{X}}
  \setbox3=\hbox{X}
  \AssertUrlBoundaryEquivalent{0}{1}{2}{3}
}

\TEST{ascii context url matches direct input}{
  \setbox0=\hbox{abc\url{X}def}
  \setbox1=\hbox{abcXdef}
  \setbox2=\hbox{\url{X}}
  \setbox3=\hbox{X}
  \AssertUrlBoundaryEquivalent{0}{1}{2}{3}
}

\END

\end{document}
