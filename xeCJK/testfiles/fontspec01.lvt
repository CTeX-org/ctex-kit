\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{CJKfontspec inline change}{
  \setbox0=\hbox{字}
  \TYPE{default: \the\wd0}
  \setbox1=\hbox{{\CJKfontspec{FandolKai-Regular.otf}字}}
  \TYPE{kai: \the\wd1}
}

\TEST{addCJKfontfeatures BoldFont}{
  \setbox0=\hbox{字}
  \TYPE{normal: \the\wd0}
  \setbox1=\hbox{{\addCJKfontfeatures{AutoFakeBold=3}\bfseries 字}}
  \TYPE{fakebold: \the\wd1}
}

\END

\end{document}
