\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}
\xeCJKsetup{experiment/punct-measure-fix}

\begin{document}

\START

\loggingoutput

\TEST{paragraph ending with fullwidth punct (fix enabled)}{
  \hsize=345pt
  天地玄黄，宇宙洪荒。日月盈昃，辰宿列张。寒来暑往，秋收冬藏。闰余成岁，律吕调阳。
  \clearpage
}

\TEST{paragraph ending with fullwidth punct in minipage}{
  \begin{minipage}{345pt}
    天地玄黄，宇宙洪荒。日月盈昃，辰宿列张。
  \end{minipage}
  \clearpage
}

\TEST{tabular with fullwidth punct}{
  \begin{tabular}{|r|}
    \hline
    天地玄黄。\\
    \hline
  \end{tabular}
  \clearpage
}

\END

