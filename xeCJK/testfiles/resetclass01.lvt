\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{reclassify then reset}{
  \setbox0=\hbox{еӯ—Aеӯ—}
  \TYPE{before:~\the\wd0}
  \xeCJKDeclareCharClass{CJK}{"0041}
  \setbox1=\hbox{еӯ—Aеӯ—}
  \TYPE{reclassified:~\the\wd1}
  \xeCJKResetCharClass
  \setbox2=\hbox{еӯ—Aеӯ—}
  \TYPE{after-reset:~\the\wd2}
}

\TEST{ResetPunctClass restores punct class}{
  \setbox0=\hbox{еӯ—пјҢеӯ—}
  \TYPE{before-punct:~\the\wd0}
  \xeCJKResetPunctClass
  \setbox1=\hbox{еӯ—пјҢеӯ—}
  \TYPE{after-reset-punct:~\the\wd1}
  \ifdim\wd0=\wd1
    \TYPE{PASS:~punct~class~preserved}
  \else
    \TYPE{widths~differ:~\the\wd0\space vs~\the\wd1}
  \fi
}

\END

\end{document}
