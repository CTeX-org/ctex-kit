\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\usepackage{xcolor}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{CJKecglue~survives~\textcolor~around~Default}{
  \setbox0=\hbox{文AB字}
  \setbox1=\hbox{文\textcolor{red}{AB}字}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\TEST{CJKglue~survives~\textcolor~around~CJK}{
  \setbox0=\hbox{文字文}
  \setbox1=\hbox{文\textcolor{red}{字}文}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\TEST{CJKecglue~survives~\textcolor~around~single~digit}{
  \setbox0=\hbox{终于3岁}
  \setbox1=\hbox{终于\textcolor{red}{3}岁}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\TEST{CJKecglue~with~mixed~content~in~\textcolor}{
  \setbox0=\hbox{中word中}
  \setbox1=\hbox{中\textcolor{red}{word}中}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\TEST{nested~\textcolor~preserves~CJKecglue}{
  \setbox0=\hbox{文AB字}
  \setbox1=\hbox{文\textcolor{red}{\textcolor{blue}{AB}}字}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\END

\end{document}
