\input{regression-test}

\documentclass{article}

\usepackage{xeCJK,xeCJKfntef}
\setCJKmainfont[BoldFont=FandolHei-Regular.otf]{FandolSong-Regular.otf}

\showboxdepth=5
\showboxbreadth=100

\begin{document}

\START

% ---------- TEST 1 ----------
% fntef 组结束后，CJK 字符间 \quad 不应被吃掉。
% \quad 没有 shrink 分量，glueshrink 检查应将其排除。
\OMIT
\ExplSyntaxOn
\setbox0=\hbox{ \CJKunderdot{文字} \quad 文字 }
\setbox2=\hbox{ 文字 \quad 文字 }
\ExplSyntaxOff
\TIMO

\TEST{fntef followed by quad preserves spacing}{
  \typeout{underdot+quad~ width:~ \the\wd0}
  \typeout{plain+quad~ width:~ \the\wd2}
  \showbox0
}

% ---------- TEST 2 ----------
% fntef 组结束后，显式空格 \ 不应被误处理。
% \ 产生的词间空格带 shrink，但 boolean flag 在非 fntef 尾部不应触发。
\OMIT
\ExplSyntaxOn
\setbox0=\hbox{ 汉字\ \CJKunderdot{文字} }
\setbox2=\hbox{ 汉字\ 文字 }
\ExplSyntaxOff
\TIMO

\TEST{explicit~backslash-space~before~fntef~preserved}{
  \typeout{space+underdot~ width:~ \the\wd0}
  \typeout{space+plain~ width:~ \the\wd2}
  \showbox0
}

% ---------- TEST 3 ----------
% fntef 组结束后接 CJK 标点，标点间距不应受影响。
\OMIT
\ExplSyntaxOn
\setbox0=\hbox{ \CJKunderdot{文字}，文字 }
\setbox2=\hbox{ 文字，文字 }
\ExplSyntaxOff
\TIMO

\TEST{fntef~followed~by~CJK~punct~correct~spacing}{
  \typeout{underdot+punct~ width:~ \the\wd0}
  \typeout{plain+punct~ width:~ \the\wd2}
  \showbox0
}

\END

\end{document}
