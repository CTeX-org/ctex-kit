\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\loggingoutput

\ExplSyntaxOn
\clist_map_inline:nn
  { quanjiao, banjiao, kaiming }
  {
    \TEST{punctstyle~=~#1}{
      \group_begin:
        \xeCJKsetup { PunctStyle = #1 }
        标点、标点，标点。标点、标点，标点。标点、标点，标点。
        「标点」、「『标点』」，《标点》、〈标点〉。
        「标点。」「『标』点，」《标点。》
      \group_end:
      \clearpage
    }
  }
\ExplSyntaxOff

\END

