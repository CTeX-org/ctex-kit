\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\usepackage{xcolor}
\usepackage{hyperref}
\usepackage{hypdoc}

\setCJKmainfont{FandolSong-Regular.otf}
\setCJKmonofont{FandolFang-Regular.otf}

\newskip\BoundaryExplicitSpace
\BoundaryExplicitSpace=3.33333pt plus 1.66666pt minus 1.11111pt

\showboxbreadth=100
\showboxdepth=20

\begin{document}

% Keep lazy fontspec family creation outside the normalized test log.
\setbox0=\hbox{\ttfamily 中文}

\START

\loggingoutput
\xeCJKsetup{CJKecglue={\hskip 5pt},CJKglue={\hskip 1pt}}

\TEST{box capture in paragraph mode}{
  \setbox0=\vbox{%
    \hsize=100pt
    \noindent 中\mbox{Alpha}文\par
  }%
  \box0
  \clearpage
}

\TEST{transparent capture preserves a source-space boundary}{
  \setbox0=\hbox{中\null 中文}%
  \box0
  \clearpage
}

\TEST{stream capture follows linked CJK output}{
  \setbox0=\hbox{A\href{https://example.com}{中文}B}%
  \box0
  \clearpage
}

\TEST{explicit elastic glue is not a source space}{
  \setbox0=\hbox{%
    中\hskip 7pt plus 2pt minus 1pt\mbox{Alpha}文%
  }%
  \box0
  \clearpage
}

\TEST{entry capture preserves an explicit interword-sized glue}{
  \setbox0=\hbox{%
    中\hskip\BoundaryExplicitSpace\mbox{Alpha}文%
  }%
  \box0
  \clearpage
}

\TEST{direct explicit interword-sized glue remains explicit}{
  \setbox0=\hbox{%
    中\hskip\BoundaryExplicitSpace Alpha%
  }%
  \box0
  \clearpage
}

\TEST{a zero kern protects following explicit interword-sized glue}{
  \setbox0=\hbox{%
    中\mbox{中文}\kern0pt\hskip\BoundaryExplicitSpace Alpha%
  }%
  \box0
  \clearpage
}

\TEST{post-transparent null does not cross explicit glue}{
  \setbox0=\hbox{中\hskip 7pt\null Alpha}%
  \box0
  \clearpage
}

\TEST{assigned null does not replay stale state across explicit glue}{
  \setbox2=\hbox{}%
  \setbox0=\hbox{中\hskip 7pt\setbox2\null Alpha}%
  \box0
  \clearpage
}

\TEST{cs stream reports its actual western tail}{
  \setbox0=\hbox{中\cs{Alpha}文}%
  \box0
  \clearpage
}

\TEST{cs stream reports its actual CJK tail}{
  \setbox0=\hbox{A\cs{中文}B}%
  \box0
  \clearpage
}

\END

\end{document}
