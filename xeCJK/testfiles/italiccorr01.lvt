\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{textit followed by CJK has ecglue}{
  \setbox0=\hbox{字abc字}
  \setbox1=\hbox{字\textit{abc}字}
  \TYPE{plain:~\the\wd0}
  \TYPE{italic:~\the\wd1}
}

\TEST{textit with trailing space before CJK}{
  \setbox0=\hbox{字\textit{abc} 字}
  \setbox1=\hbox{字\textit{abc}字}
  \TYPE{with-space:~\the\wd0}
  \TYPE{no-space:~\the\wd1}
}

\TEST{emph CJK followed by CJK}{
  \setbox0=\hbox{字强调字}
  \setbox1=\hbox{字\emph{强调}字}
  \TYPE{plain:~\the\wd0}
  \TYPE{emph:~\the\wd1}
}

\TEST{textbf followed by CJK has ecglue}{
  \setbox0=\hbox{字abc字}
  \setbox1=\hbox{字\textbf{abc}字}
  \TYPE{plain:~\the\wd0}
  \TYPE{bold:~\the\wd1}
}

\END

\end{document}
