\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\showboxbreadth=100
\showboxdepth=10

\begin{document}

\START

\loggingoutput

% #919: double CJKecglue on the RIGHT side of \verb when a source space
% follows, in PARAGRAPH mode only. Root cause: TeX emits the language
% whatsit lazily -- after \verb's group closes, the whatsit only enters
% the horizontal list when the NEXT char node comes in, so the
% source-space inter-word glue lands BEFORE the \setlanguage whatsit:
%
%   kern pair -> glue(source space) -> setlanguage -> [probe point]
%
% Historically, the following CJK transition treated that whatsit as a
% recoverable Default boundary and emitted another ecglue on top of the
% existing source-space glue -> double spacing.
%
% The #919 fix appends \__xeCJK_flush_language_whatsit: to \verb@egroup,
% forcing the whatsit out immediately at group close:
%
%   kern pair -> setlanguage -> glue(source space) -> [probe point]
%
% The #992 stream capture saves the boundary before \verb's leading \null;
% the flush keeps the language whatsit inside that capture, and its end
% replays the actual final Default/CJK class after the whatsit. The generic
% whatsit recovery has been removed. The whatsit only exists in outer horizontal
% mode (paragraph), so the box constructions below use \vbox{...\par};
% restricted \hbox mode still supplies the direct node/width reference.
%
% NOTE: checkopts has -halt-on-error and \showbox reports "! OK.", so we use
% \box instead and add \loggingoutput before. Width comparisons (\TYPE of \wd
% values) serve as the oracle for the other scenarios.

% \verb cannot appear inside a macro argument, so boxes are set at the
% top level.

% Default inter-word space and CJKecglue have the same natural width in
% this font. All four source-space variants therefore have the same
% natural width once both verb boundaries follow the direct-input oracle.
\setbox0=\hbox{用 \verb|X| 无}
\setbox1=\hbox{用 \verb|X|无}
\setbox2=\hbox{用\verb|X|无}
\setbox3=\hbox{用\verb|X| 无}

\TEST{restricted hbox widths (inventory)}{
  % In restricted horizontal mode there is no language whatsit. The
  % capture must nevertheless restore both boundaries for all four
  % source-space combinations.
  \TYPE{1sp/1sp hbox: \the\wd0}
  \TYPE{1sp/0sp hbox: \the\wd1}
  \TYPE{0sp/0sp hbox: \the\wd2}
  \TYPE{0sp/1sp hbox: \the\wd3}
}

% Paragraph mode: measure the natural width of the single line via
% \parbox-free construction -- unskip the infinite fills and remeasure.
% Simpler oracle: compare paragraph-mode pairs whose widths must be
% equal after the fix.
\setbox4=\vbox{\hsize=10cm \noindent 用 \verb|X| 无\par}
\setbox5=\vbox{\hsize=10cm \noindent 用 \verb|X|无\par}
\setbox6=\vbox{\hsize=10cm \noindent 用\verb|X|无\par}
\setbox7=\vbox{\hsize=10cm \noindent ab \verb|X| cd\par}

\TEST{paragraph-mode glue accounting via badness}{
  % All these paragraphs are single lines stretched to \hsize; the glue
  % set ratio embedded in \box output differs when an extra 3.33pt
  % glue is present. We expose it via the vbox height/depth (invariant)
  % plus the badness of the line, which reflects total stretch.
  % Before the fix box4's line had one extra ecglue (more absolute
  % width consumed -> different glue set). The definitive node-level
  % check is TEST 3's \box; here we record box dimensions as a
  % cheap cross-check that survives in the .tlg.
  \TYPE{1sp/1sp vbox: \the\wd4 x \the\ht4 + \the\dp4}
  \TYPE{1sp/0sp vbox: \the\wd5 x \the\ht5 + \the\dp5}
  \TYPE{0sp/0sp vbox: \the\wd6 x \the\ht6 + \the\dp6}
  \TYPE{ascii   vbox: \the\wd7 x \the\ht7 + \the\dp7}
}

\TEST{node-level dump, 1sp main scenario (919)}{
  % THE oracle: before #919 the right side showed TWO 3.33pt glues
  % (source space + default recovery). The current list has one left
  % ecglue after \null/\setlanguage2, a replayed Default marker after X,
  % then \setlanguage0 and one right source-space glue.
  % Must use \box, or -halt-on-error will stops at \showbox's "! OK."
  \box4
  \clearpage
}

\END

\end{document}
