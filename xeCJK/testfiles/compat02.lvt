\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{fallback enable disable cycle}{
  \xeCJKenablefallback
  \setbox0=\hbox{еӯ—}
  \TYPE{enabled: \the\wd0}
  \xeCJKdisablefallback
  \setbox1=\hbox{еӯ—}
  \TYPE{disabled: \the\wd1}
  \xeCJKenablefallback
  \setbox2=\hbox{еӯ—}
  \TYPE{re-enabled: \the\wd2}
}

\TEST{xeCJKallowbreakbetweenpuncts compat}{
  \xeCJKallowbreakbetweenpuncts
  \setbox0=\hbox{еӯ—пјҢеӯ—гҖӮеӯ—}
  \TYPE{allow: \the\wd0}
  \xeCJKnobreakbetweenpuncts
  \setbox1=\hbox{еӯ—пјҢеӯ—гҖӮеӯ—}
  \TYPE{nobreak: \the\wd1}
}

\END

\end{document}
