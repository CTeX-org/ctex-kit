\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\newcommand\AssertVerbBoundaryEquivalent[4]{%
  \dimen0=\wd#1
  \advance\dimen0 by -\wd#2
  \advance\dimen0 by -\wd#3
  \advance\dimen0 by \wd#4
  \ifdim\dimen0<0pt
    \dimen0=-\dimen0
  \fi
  \ifdim\dimen0<0.01pt
    \TYPE{PASS: boundary delta \the\dimen0}%
  \else
    \TYPE{FAIL: boundary delta \the\dimen0}%
  \fi
}

\begin{document}

\START

% #910: CJK followed by \verb should have ecglue inserted on the left side.
% Without the fix, the boundary marker kern (written by the source space
% before \verb triggering CJK->Boundary) is shadowed by \null's 0x0 hbox,
% so the left ecglue is lost. This is structurally identical to #873
% (\HD@target via \raisebox). The current fix uses an auto stream capture
% around the complete delimiter-scanning command.

% \verb cannot appear inside a macro argument (LaTeX rejects "\verb illegal
% in argument"), so we set up the boxes at the top level and check widths
% inside \TEST.

\setbox0=\hbox{用 \verb|X| 无}
\setbox1=\hbox{用 X 无}
\setbox2=\hbox{用 \verb*|X| 无}
\setbox3=\hbox{$\verb|X|$}
\setbox4=\hbox{abc \verb|X| def}
\setbox5=\hbox{abc X def}
\setbox6=\hbox{\verb|X|}
\setbox7=\hbox{X}
\setbox8=\hbox{\verb*|X|}

\TEST{ecglue between CJK and verb with source space (910)}{
  % Remove the command's intrinsic width delta, then compare the complete
  % CJK--Default--CJK context with the corresponding direct-input oracle.
  \AssertVerbBoundaryEquivalent{0}{1}{6}{7}
}

\TEST{ecglue between CJK and verb*}{
  \AssertVerbBoundaryEquivalent{2}{1}{8}{7}
}

\TEST{verb inside math mode is not patched}{
  % \verb in math mode goes through the \hbox branch and never inserts
  % \leavevmode\null. Just check this still compiles and the patch
  % does not interfere.
  \TYPE{INFO: math-mode verb width: \the\wd3}
}

\TEST{ascii context verb matches direct input}{
  \AssertVerbBoundaryEquivalent{4}{5}{6}{7}
}

\END

\end{document}
