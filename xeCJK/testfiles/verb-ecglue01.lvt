\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

% #910: CJK followed by \verb should have ecglue inserted on the left side.
% Without the fix, the boundary marker kern (written by the source space
% before \verb triggering CJK->Boundary) is shadowed by \null's 0x0 hbox,
% so the left ecglue is lost. This is structurally identical to #873
% (\HD@target via \raisebox); the fix uses the #880-style drain pattern.

% \verb cannot appear inside a macro argument (LaTeX rejects "\verb illegal
% in argument"), so we set up the boxes at the top level and check widths
% inside \TEST.

\setbox0=\hbox{用 \verb|X| 无}
\setbox1=\hbox{用 \hbox{} 无}
\setbox2=\hbox{用 \verb*|X| 无}
\setbox3=\hbox{$\verb|X|$}
\setbox4=\hbox{abc \verb|X| def}

\TEST{ecglue between CJK and verb with source space (910)}{
  % box0 = CJK verb CJK with source spaces.
  % box1 = same but with a bare 0x0 hbox instead of verb content; this is
  %        the "no ecglue" baseline (no CJK marker kern from a source space
  %        triggering CJK->Boundary because the verb content is not present
  %        to receive interchar transitions on the right side).
  % After the fix, box0 picks up an ecglue drained from the boundary
  % marker; box0 should be wider than box1.
  \dimen0=\wd0 \advance\dimen0 by -\wd1
  \ifdim\dimen0>2pt
    \TYPE{PASS: left ecglue present: \the\dimen0}
  \else
    \TYPE{FAIL: left ecglue missing: \the\dimen0}
  \fi
}

\TEST{ecglue between CJK and verb*}{
  \dimen0=\wd2 \advance\dimen0 by -\wd1
  \ifdim\dimen0>2pt
    \TYPE{PASS: verb* left ecglue present: \the\dimen0}
  \else
    \TYPE{FAIL: verb* left ecglue missing: \the\dimen0}
  \fi
}

\TEST{verb inside math mode is not patched}{
  % \verb in math mode goes through the \hbox branch and never inserts
  % \leavevmode\null. Just check this still compiles and the patch
  % does not interfere.
  \TYPE{INFO: math-mode verb width: \the\wd3}
}

\TEST{ascii context verb unchanged (non-regression)}{
  % Patch must be a no-op when no CJK marker is on the node stack.
  \TYPE{INFO: ASCII verb width: \the\wd4}
}

\END

\end{document}
