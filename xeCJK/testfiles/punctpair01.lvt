\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{consecutive punct compression}{
  \setbox0=\hbox{「」}
  \setbox2=\hbox{「}
  \setbox3=\hbox{」}
  \TYPE{pair: \the\wd0}
  \TYPE{left: \the\wd2}
  \TYPE{right: \the\wd3}
}

\TEST{nested quotes punct}{
  \setbox0=\hbox{「『」』}
  \TYPE{nested: \the\wd0}
}

\TEST{opening punct at line start}{
  \setbox0=\hbox{「字字字」}
  \TYPE{quoted: \the\wd0}
}

\TEST{closing then opening}{
  \setbox0=\hbox{」「}
  \TYPE{close-open: \the\wd0}
}

\END

\end{document}
