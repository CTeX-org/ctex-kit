\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{U+200B~does~not~affect~CJK~glue}{
  \setbox0=\hbox{文字文字}
  \setbox1=\hbox{文^^^^200b字^^^^200b文^^^^200b字}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\TEST{U+200B~does~not~affect~CJK-Latin~boundary}{
  \setbox0=\hbox{文AB字}
  \setbox1=\hbox{文^^^^200bAB^^^^200b字}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\TEST{U+200C~is~ignored}{
  \setbox0=\hbox{文字}
  \setbox1=\hbox{文^^^^200c字}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\TEST{U+200D~is~ignored}{
  \setbox0=\hbox{文字}
  \setbox1=\hbox{文^^^^200d字}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\TEST{U+2060~is~ignored}{
  \setbox0=\hbox{文字}
  \setbox1=\hbox{文^^^^2060字}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\TEST{U+FEFF~is~ignored}{
  \setbox0=\hbox{文字}
  \setbox1=\hbox{文^^^^feff字}
  \TYPE{\the\wd0}
  \TYPE{\the\wd1}
  \ifdim\wd0=\wd1 \TYPE{PASS}\else\TYPE{FAIL}\fi
}

\END

\end{document}
