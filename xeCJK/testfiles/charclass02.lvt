\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{CM class no glue between CM and CJK}{
  \xeCJKDeclareCharClass{CM}{"0300}
  \setbox0=\hbox{字}
  \TYPE{CJK-only: \the\wd0}
}

\TEST{Hangul Jamo syllable classes}{
  \TYPE{Legacy class: \the\XeTeXcharclass`字}
  \TYPE{Jamo L: \the\XeTeXcharclass"113B}
  \TYPE{Jamo V: \the\XeTeXcharclass"119F}
  \TYPE{Jamo T: \the\XeTeXcharclass"11EB}
}

\TEST{NormalSpace class behavior}{
  \setbox0=\hbox{字:字}
  \setbox2=\hbox{字}
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd2
  \TYPE{colon-gap: \the\dimen0}
}

\END

\end{document}
