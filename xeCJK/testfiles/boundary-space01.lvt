\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\newcommand\cjkmacro{方程}
\newcommand\latmacro{Equation}

\begin{document}

\START

\TEST{CJK + newline + macro producing CJK (issue 324)}{
  \setbox0=\hbox{参见
\cjkmacro}
  \setbox2=\hbox{参见\cjkmacro}
  \TYPE{with-newline:~\the\wd0}
  \TYPE{without-newline:~\the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS:~widths~are~equal}
  \else
    \TYPE{FAIL:~widths~differ}
  \fi
}

\TEST{CJK + newline + macro producing Default}{
  \setbox0=\hbox{参见
\latmacro}
  \TYPE{with-newline:~\the\wd0}
}

\TEST{CJK + newline + textbf CJK}{
  \setbox0=\hbox{参见
\textbf{方程}}
  \setbox2=\hbox{参见\textbf{方程}}
  \TYPE{with-newline:~\the\wd0}
  \TYPE{without-newline:~\the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS:~widths~are~equal}
  \else
    \TYPE{FAIL:~widths~differ}
  \fi
}

\TEST{CJK + no newline + macro (no regression)}{
  \setbox0=\hbox{参见\cjkmacro}
  \TYPE{no-newline:~\the\wd0}
}

\END

\end{document}
