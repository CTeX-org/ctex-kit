\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{CJK~+~brace~group~+~space~+~CJK~(issue~770)}{
  \setbox0=\hbox{前{中} 后}
  \setbox2=\hbox{前中 后}
  \TYPE{with-braces:~\the\wd0}
  \TYPE{without-braces:~\the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS:~widths~match}
  \else
    \TYPE{FAIL:~widths~differ~by~\the\dimexpr\wd0-\wd2\relax}
  \fi
}

\TEST{CJK~+~brace~group~+~no~space~+~CJK}{
  \setbox0=\hbox{前{中}后}
  \setbox2=\hbox{前中后}
  \TYPE{with-braces:~\the\wd0}
  \TYPE{without-braces:~\the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS:~widths~match}
  \else
    \TYPE{FAIL:~widths~differ~by~\the\dimexpr\wd0-\wd2\relax}
  \fi
}

\TEST{CJK~+~backslash-space~preserved}{
  \setbox0=\hbox{三\ 分}
  \TYPE{width:~\the\wd0}
}

\END

\end{document}
