\input{regression-test}

\documentclass{article}

\usepackage{xeCJK,xcolor}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{CJK + brace group + space + CJK (issue 831)}{
  \setbox0=\hbox{前{中} 后}
  \setbox2=\hbox{前中 后}
  \TYPE{with-braces: \the\wd0}
  \TYPE{without-braces: \the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS: widths match}
  \else
    \TYPE{FAIL: widths differ by \the\dimexpr\wd0-\wd2\relax}
  \fi
}

\TEST{CJK + brace group + no space + CJK}{
  \setbox0=\hbox{前{中}后}
  \setbox2=\hbox{前中后}
  \TYPE{with-braces: \the\wd0}
  \TYPE{without-braces: \the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS: widths match}
  \else
    \TYPE{FAIL: widths differ by \the\dimexpr\wd0-\wd2\relax}
  \fi
}

\TEST{CJK + mbox + space + CJK}{
  \setbox0=\hbox{前 \mbox{中} 后}
  \setbox2=\hbox{前 中 后}
  \TYPE{with-mbox: \the\wd0}
  \TYPE{plain: \the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS: widths match}
  \else
    \TYPE{FAIL: widths differ by \the\dimexpr\wd0-\wd2\relax}
  \fi
}

\TEST{CJK + textcolor + space + CJK}{
  \setbox0=\hbox{前 \textcolor{red}{中} 后}
  \setbox2=\hbox{前 中 后}
  \TYPE{with-textcolor: \the\wd0}
  \TYPE{plain: \the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS: widths match}
  \else
    \TYPE{FAIL: widths differ by \the\dimexpr\wd0-\wd2\relax}
  \fi
}

\TEST{CJK + backslash-space preserved}{
  \setbox0=\hbox{三\ 分}
  \TYPE{width: \the\wd0}
}

\TEST{CJK + colorbox + space + CJK}{
  \setbox0=\hbox{前 \colorbox{yellow}{中} 后}
  \setbox2=\hbox{前\colorbox{yellow}{中}后}
  \TYPE{with-space: \the\wd0}
  \TYPE{no-space: \the\wd2}
  \ifdim\wd0=\wd2
    \TYPE{PASS: widths match}
  \else
    \TYPE{FAIL: widths differ by \the\dimexpr\wd0-\wd2\relax}
  \fi
}

\END

\end{document}
