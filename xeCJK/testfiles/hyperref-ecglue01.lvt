\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\usepackage{hyperref}
\usepackage{xcolor}
\setCJKmainfont{FandolSong-Regular.otf}
\setCJKmonofont{FandolFang-Regular.otf}

\begin{document}

\OMIT
\setbox0=\hbox{\url{X}}
\TIMO

\START

% Test 1: hyperref link annotation between CJK chars should have ecglue (#809)
%         \hyperref exercises the same \Hy@BeginAnnot path as \ref
\TEST{ecglue around hyperref link annotation (809)}{
  \setbox0=\hbox{图1图}
  \setbox1=\hbox{图\hyperref[fig]{1}图}
  \ifdim\wd0=\wd1
    \TYPE{PASS: link annotation matches plain digit}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 2: bann special at start should not insert spurious ecglue (#810)
%         simulates TOC scenario: annotation starts before CJK text
\TEST{no spurious ecglue after bann at start (810)}{
  \setbox0=\hbox{信箱和冰箱会领导}
  \setbox1=\hbox{\special{pdf:bann test}信箱和冰箱会领导\special{pdf:eann}}
  \ifdim\wd0=\wd1
    \TYPE{PASS: no extra glue after bann}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 3: textcolor ecglue should still work with hyperref loaded
\TEST{textcolor ecglue with hyperref (non-regression)}{
  \setbox0=\hbox{中文test中文}
  \setbox1=\hbox{中文\textcolor{red}{test}中文}
  \ifdim\wd0=\wd1
    \TYPE{PASS: ecglue preserved}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 4: CJK text inside hyperref link should not get extra ecglue (#810)
%         simulates TOC section entry: link wraps CJK-only content
\TEST{no extra ecglue inside CJK-only link (810)}{
  \setbox0=\hbox{信箱和冰箱会领导}
  \setbox1=\hbox{\hyperref[sec]{信箱和冰箱会领导}}
  \ifdim\wd0=\wd1
    \TYPE{PASS: no extra glue in CJK link}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 5: the end-annotation whatsit after a linked URL must not hide the
%         math node which supplies the URL-to-CJK boundary (#972).
\TEST{right ecglue after hyperref url (972)}{
  \setbox0=\hbox{测\nolinkurl{X}无}
  \setbox1=\hbox{测\url{X}无}
  \ifdim\wd0=\wd1
    \TYPE{PASS: linked and unlinked URL widths match}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 6: check the right boundary directly instead of relying only on the
%         total width comparison above.  The left and right boundaries of
%         the same one-character URL should contribute equal ecglue.
\TEST{equal ecglue on both sides of hyperref url (972)}{
  \setbox0=\hbox{测\url{X}}
  \setbox1=\hbox{\url{X}}
  \setbox2=\hbox{测}
  \dimen0=\wd0 \advance\dimen0 by -\wd1 \advance\dimen0 by -\wd2
  \setbox3=\hbox{\url{X}无}
  \setbox4=\hbox{无}
  \dimen2=\wd3 \advance\dimen2 by -\wd1 \advance\dimen2 by -\wd4
  \ifdim\dimen0=\dimen2
    \TYPE{PASS: URL boundary ecglue is symmetric}
  \else
    \TYPE{FAIL: left \the\dimen0\space vs right \the\dimen2}
  \fi
}

% Test 7: a source space after the linked URL is absorbed just as it is at
%         an ordinary Default-to-CJK boundary; it must not add a second gap.
\TEST{space after hyperref url is absorbed (972)}{
  \setbox0=\hbox{测\url{X} 无}
  \setbox1=\hbox{测\url{X}无}
  \ifdim\wd0=\wd1
    \TYPE{PASS: source space after URL is absorbed}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 8: the end-annotation repair is keyed to a real trailing math node,
%         not to the public \url command.  Compare only the right boundary;
%         the left edge of a generic math link follows a separate path.
\TEST{right ecglue after math-ending hyperlink (972)}{
  \setbox0=\hbox{\href{https://example.com}{$X$}无}
  \setbox1=\hbox{\href{https://example.com}{$X$}}
  \setbox2=\hbox{$X$无}
  \setbox3=\hbox{$X$}
  \dimen0=\wd0 \advance\dimen0 by -\wd1
  \dimen2=\wd2 \advance\dimen2 by -\wd3
  \ifdim\dimen0=\dimen2
    \TYPE{PASS: linked and unlinked math right boundaries match}
  \else
    \TYPE{FAIL: linked \the\dimen0\space vs plain \the\dimen2}
  \fi
}

% Test 9: color selection inserts another whatsit before the CJK character.
%         The trusted link-end marker must survive the existing color patch.
\TEST{right ecglue after hyperref url and color switch (972)}{
  \setbox0=\hbox{测\nolinkurl{X}无}
  \setbox1=\hbox{测\url{X}\textcolor{red}{无}}
  \ifdim\wd0=\wd1
    \TYPE{PASS: URL boundary survives color switch}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 10: a second annotation starts before the following CJK text.  The
%          first annotation's auto stream must hand its observed Default
%          tail to the following annotation without trusting stale state.
\TEST{right ecglue between hyperref url and CJK link (972)}{
  \setbox0=\hbox{测\nolinkurl{X}无}
  \setbox1=\hbox{测\url{X}\href{https://example.com}{无}}
  \ifdim\wd0=\wd1
    \TYPE{PASS: URL boundary survives following annotation}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

\END

\end{document}
