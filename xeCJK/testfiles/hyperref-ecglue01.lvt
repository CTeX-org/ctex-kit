\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\usepackage{hyperref}
\usepackage{xcolor}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

% Test 1: hyperref link annotation between CJK chars should have ecglue (#809)
%         \hyperref exercises the same \Hy@BeginAnnot path as \ref
\TEST{ecglue around hyperref link annotation (809)}{
  \setbox0=\hbox{图1图}
  \setbox1=\hbox{图\hyperref[fig]{1}图}
  \ifdim\wd0=\wd1
    \TYPE{PASS: link annotation matches plain digit}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 2: bann special at start should not insert spurious ecglue (#810)
%         simulates TOC scenario: annotation starts before CJK text
\TEST{no spurious ecglue after bann at start (810)}{
  \setbox0=\hbox{信箱和冰箱会领导}
  \setbox1=\hbox{\special{pdf:bann test}信箱和冰箱会领导\special{pdf:eann}}
  \ifdim\wd0=\wd1
    \TYPE{PASS: no extra glue after bann}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 3: textcolor ecglue should still work with hyperref loaded
\TEST{textcolor ecglue with hyperref (non-regression)}{
  \setbox0=\hbox{中文test中文}
  \setbox1=\hbox{中文\textcolor{red}{test}中文}
  \ifdim\wd0=\wd1
    \TYPE{PASS: ecglue preserved}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 4: CJK text inside hyperref link should not get extra ecglue (#810)
%         simulates TOC section entry: link wraps CJK-only content
\TEST{no extra ecglue inside CJK-only link (810)}{
  \setbox0=\hbox{信箱和冰箱会领导}
  \setbox1=\hbox{\hyperref[sec]{信箱和冰箱会领导}}
  \ifdim\wd0=\wd1
    \TYPE{PASS: no extra glue in CJK link}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

\END

\end{document}
