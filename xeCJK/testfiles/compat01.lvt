\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{compat punctstyle command}{
  \punctstyle{banjiao}
  \setbox0=\hbox{еӯ—пјҢеӯ—}
  \TYPE{banjiao-via-compat: \the\wd0}
  \punctstyle{quanjiao}
  \setbox1=\hbox{еӯ—пјҢеӯ—}
  \TYPE{quanjiao-via-compat: \the\wd1}
}

\TEST{compat CJKspace CJKnospace}{
  \CJKspace
  \setbox0=\hbox{еӯ— еӯ—}
  \TYPE{CJKspace: \the\wd0}
  \CJKnospace
  \setbox1=\hbox{еӯ— еӯ—}
  \TYPE{CJKnospace: \the\wd1}
}

\TEST{compat CJKsetecglue}{
  \setbox0=\hbox{еӯ—A\kern0pt}
  \setbox2=\hbox{еӯ—}
  \setbox3=\hbox{A}
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd3
  \TYPE{default-ecglue: \the\dimen0}
  \CJKsetecglue{0.5em}
  \setbox0=\hbox{еӯ—A\kern0pt}
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd3
  \TYPE{custom-ecglue: \the\dimen0}
}

\TEST{compat xeCJKplainchr}{
  \xeCJKplainchr
  \setbox0=\hbox{еӯ—пјҢеӯ—}
  \TYPE{plain-via-compat: \the\wd0}
}

\END

\end{document}
