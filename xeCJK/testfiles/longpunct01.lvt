\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{LongPunct em-dash width}{
  \setbox0=\hbox{еӯ—вҖ”вҖ”еӯ—}
  \setbox2=\hbox{еӯ—}
  \TYPE{em-dash-ctx:~\the\wd0}
  \TYPE{single-char:~\the\wd2}
}

\TEST{LongPunct ellipsis width}{
  \setbox0=\hbox{еӯ—вҖҰвҖҰеӯ—}
  \setbox2=\hbox{еӯ—}
  \TYPE{ellipsis-ctx:~\the\wd0}
  \TYPE{single-char:~\the\wd2}
}

\TEST{MiddlePunct centered dot}{
  \setbox0=\hbox{еӯ—В·еӯ—}
  \setbox2=\hbox{еӯ—}
  \TYPE{middot-ctx:~\the\wd0}
  \TYPE{single-char:~\the\wd2}
}

\END

\end{document}
