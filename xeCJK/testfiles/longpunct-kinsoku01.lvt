% Issue #456: line-break rules (kinsoku) between long puncts and other puncts
% A break at a long-punct boundary is legal only if BOTH sides satisfy
% kinsoku: no FullLeft hanging at line end, no FullRight / NoBreakLongPunct
% falling at line start.
\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\loggingoutput

\TEST{FullLeft before dash must not hang at line end}{
  % Old behavior broke after the opening quote / paren.
  \hsize=9em
  еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—вҖңвҖ”вҖ”вҖқеӯ—еӯ—еӯ—еӯ—еӯ—еӯ—
  \clearpage
  \hsize=9em
  еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—пјҲвҖ”вҖ”пјүеӯ—еӯ—еӯ—еӯ—еӯ—
  \clearpage
}

\TEST{FullRight after dash must not fall at line start}{
  % Old behavior broke before the comma / period.
  \hsize=9em
  еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—з ҙжҠҳвҖ”вҖ”пјҢеӯ—еӯ—еӯ—еӯ—еӯ—еӯ—
  \clearpage
  \hsize=9em
  еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—з ҙжҠҳвҖ”вҖ”гҖӮеӯ—еӯ—еӯ—еӯ—еӯ—еӯ—
  \clearpage
}

\TEST{NoBreakLongPunct after dash must not fall at line start}{
  \hsize=9em
  еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—з ҙжҠҳвҖ”вҖ”вҖҰвҖҰеӯ—еӯ—еӯ—еӯ—еӯ—
  \clearpage
}

\TEST{legal break points are kept}{
  % Break after FullRight, before long punct: allowed.
  \hsize=9em
  еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—з ҙжҠҳпјҢвҖ”вҖ”еӯ—еӯ—еӯ—еӯ—еӯ—
  \clearpage
  \hsize=9em
  еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—еӯ—з ҙжҠҳвҖҰвҖҰвҖ”вҖ”еӯ—еӯ—еӯ—еӯ—еӯ—
  \clearpage
}

\END

\end{document}
