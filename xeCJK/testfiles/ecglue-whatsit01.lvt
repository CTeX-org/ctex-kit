\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\usepackage{xcolor}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

% Test 1: whatsit between hbox and Default char
%         should NOT insert extra CJKecglue inside brackets (#803)
\TEST{no extra ecglue after hbox+whatsit (803)}{
  \setbox0=\hbox{中文\hbox{[}1}
  \setbox1=\hbox{中文\hbox{[}\special{pdf:bann test}1}
  \ifdim\wd0=\wd1
    \TYPE{PASS}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 2: textcolor between CJK and Default should still get ecglue (#315)
\TEST{ecglue preserved after color whatsit (315)}{
  \setbox0=\hbox{中文X}
  \setbox1=\hbox{中文\textcolor{red}{X}}
  \ifdim\wd0=\wd1
    \TYPE{PASS: both have ecglue}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

% Test 3: color change within CJK text (no ecglue expected)
\TEST{no ecglue within CJK after color}{
  \setbox0=\hbox{中文字}
  \setbox1=\hbox{中\textcolor{red}{文}字}
  \ifdim\wd0=\wd1
    \TYPE{PASS}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

\END

\end{document}
