\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

% Simulate biblatex's \blx@pagetracker: a \protected@write producing a whatsit.
% biblatex.sty (via authoryear.bbx's \ExecuteBibliographyOptions{pagetracker})
% lets \blx@pagetracker to \blx@pagetracker@context whose body is
% \protected@write\@mainaux{}{\string\abx@aux@page{...}{...}}.
%
% xeCJK registers \blx@pagetracker as transparent: its write whatsit stays
% in the list while the surrounding marker/source-space state is restored
% after it. No generic whatsit recovery is used (#931/#992).
\makeatletter
\newwrite\bibaux
\immediate\openout\bibaux=\jobname-bibaux.aux
% Stub \blx@pagetracker: emits a \write whatsit node, same shape as biblatex.
\def\blx@pagetracker{%
  \protected@write\bibaux{}{\string\abx@aux@page{1}{\the\c@page}}%
}
\makeatother

% Simulate that biblatex has been loaded so xeCJK's begindocument/before hook
% (i.e. \__xeCJK_at_end_preamble:n) performs the registration. It reads
% \blx@pagetracker (already defined above) and wraps it.

\begin{document}

\START

\loggingoutput

\makeatletter

% --- Test 1: whatsit from stub pagetracker does not trigger spurious ecglue ---
% Before the fix, the write whatsit caused stale Default state to insert
% \CJKecglue (~3.33pt) before 张. Transparent capture now restores the
% actual entry boundary after the write, so no spurious ecglue is emitted.
%
% box0 (patched): 前文。<whatsit> 张
% box1 (baseline): 前文。张
% Both should have identical natural width — whatsit is 0-width, so any
% inserted \CJKecglue would show up as an extra ~3.33pt.

\setbox0=\hbox{前文。\blx@pagetracker 张}
\setbox1=\hbox{前文。张}

\TEST{pagetracker whatsit does not inject spurious ecglue (931)}{
  % 显式对比两个 box 的宽度: 相等 → OK, 不等 → 打印实际宽度供诊断
  \ifdim\wd0=\wd1
    \typeout{OK:~box0~and~box1~have~identical~width}%
  \else
    \typeout{FAIL:~box0~width=\the\wd0,~box1~width=\the\wd1}%
  \fi
  \box0
  \clearpage
}

\makeatother

\END

\end{document}
