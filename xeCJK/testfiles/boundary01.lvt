\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{CJK before opening bracket}{
  \setbox0=\hbox{еӯ—пјҲеӯ—пјүеӯ—}
  \TYPE{paren:~\the\wd0}
}

\TEST{CJK before Latin bracket}{
  \setbox0=\hbox{еӯ—(a)еӯ—}
  \setbox2=\hbox{еӯ—}
  \TYPE{latin-paren:~\the\wd0}
}

\TEST{CJK dash em dash}{
  \setbox0=\hbox{еӯ—вҖ”вҖ”еӯ—}
  \TYPE{em-dash:~\the\wd0}
}

\TEST{CJK number}{
  \setbox0=\hbox{еӯ—123еӯ—}
  \setbox2=\hbox{еӯ—}
  \setbox3=\hbox{123}
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd3
  \TYPE{number-ecglue:~\the\dimen0}
}

\END

\end{document}
