\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}
\usepackage{listings}

\newcommand{\passthrough}[1]{#1}

\begin{document}

\START

% Test 1: # in passthrough should match direct
\OMIT
\setbox0=\hbox{\lstinline!#!}
\setbox2=\hbox{\passthrough{\lstinline!#!}}
\TIMO

\TEST{lstinline~hash~direct~vs~passthrough}{
  \ifdim\wd0=\wd2
    \TYPE{PASS:~widths~match~(\the\wd0)}
  \else
    \TYPE{FAIL:~widths~differ~(\the\wd0\space~vs~\the\wd2)}
  \fi
}

% Test 2: abc#def in passthrough should match direct
\OMIT
\setbox0=\hbox{\lstinline!abc#def!}
\setbox2=\hbox{\passthrough{\lstinline!abc#def!}}
\TIMO

\TEST{lstinline~hash~mixed~direct~vs~passthrough}{
  \ifdim\wd0=\wd2
    \TYPE{PASS:~widths~match~(\the\wd0)}
  \else
    \TYPE{FAIL:~widths~differ~(\the\wd0\space~vs~\the\wd2)}
  \fi
}

% Test 3: ## in passthrough should match direct
\OMIT
\setbox0=\hbox{\lstinline!##!}
\setbox2=\hbox{\passthrough{\lstinline!##!}}
\TIMO

\TEST{lstinline~double~hash~direct~vs~passthrough}{
  \ifdim\wd0=\wd2
    \TYPE{PASS:~widths~match~(\the\wd0)}
  \else
    \TYPE{FAIL:~widths~differ~(\the\wd0\space~vs~\the\wd2)}
  \fi
}

% Test 4: CJK text in passthrough should match direct
\OMIT
\setbox0=\hbox{\lstinline!你好world!}
\setbox2=\hbox{\passthrough{\lstinline!你好world!}}
\TIMO

\TEST{lstinline~CJK~direct~vs~passthrough}{
  \ifdim\wd0=\wd2
    \TYPE{PASS:~widths~match~(\the\wd0)}
  \else
    \TYPE{FAIL:~widths~differ~(\the\wd0\space~vs~\the\wd2)}
  \fi
}

% Test 5: CJK with hash in passthrough should match direct
\OMIT
\setbox0=\hbox{\lstinline!#你好!}
\setbox2=\hbox{\passthrough{\lstinline!#你好!}}
\TIMO

\TEST{lstinline~hash~CJK~direct~vs~passthrough}{
  \ifdim\wd0=\wd2
    \TYPE{PASS:~widths~match~(\the\wd0)}
  \else
    \TYPE{FAIL:~widths~differ~(\the\wd0\space~vs~\the\wd2)}
  \fi
}

\END

\end{document}
