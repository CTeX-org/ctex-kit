\input{regression-test}

\documentclass{article}

\usepackage{xeCJK,xeCJKfntef}
\setCJKmainfont{FandolSong-Regular.otf}

\showboxdepth=5
\showboxbreadth=20

\newcount\centeredleaderscount
\newcount\expandedleaderscount
\makeatletter
\let\originalmarkoverwith\markoverwith
\def\markoverwith#1{%
  \ifx\ULleaders\cleaders
    \global\advance\centeredleaderscount\@ne
  \fi
  \ifx\ULleaders\xleaders
    \global\advance\expandedleaderscount\@ne
  \fi
  \originalmarkoverwith{#1}}
\makeatother

\begin{document}

\START

\loggingoutput

\OMIT
\setbox0=\hbox{\hskip3pt\CJKunderline{国}}
\setbox2=\hbox{\hskip3pt\CJKunderline-{国}\CJKunderline-{国}}
\setbox4=\hbox{\CJKxout{国}}
\TIMO

\TEST{CJKunderline uses centered leaders at a nonzero offset}{
  \box0
  \clearpage
}

\TEST{CJKunderline subtract keeps centered end spacing}{
  \box2
  \clearpage
}

\TEST{other line commands select aligned leaders}{
  \global\centeredleaderscount=0
  \global\expandedleaderscount=0
  \setbox4=\hbox{%
    \CJKunderdblline{国}\CJKunderdblline-{国}%
    \CJKunderwave{国国}\CJKunderwave-{国国}%
    \CJKsout{国}\CJKsout-{国}%
    \CJKxout{国}\CJKxout-{国}%
    \CJKunderanyline{.2em}{\rule{.2em}{.4pt}}{国}%
    \CJKunderanyline-{.2em}{\rule{.2em}{.4pt}}{国}}
  \TYPE{Centered leader calls: \the\centeredleaderscount}
  \TYPE{Expanded leader calls: \the\expandedleaderscount}
}

\TEST{CJKunderwave keeps expanded leaders across CJK boundaries}{
  \setbox4=\hbox{\hskip3pt
    \CJKunderwave{国国}\quad
    \CJKunderwave-{国国}\CJKunderwave-{国国}}
  \box4
  \clearpage
}

\END

\end{document}
