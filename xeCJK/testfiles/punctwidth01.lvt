\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\xeCJKsetwidth{пјҢ}{1em}
\xeCJKsetkern{пјҢ}{гҖӮ}{0pt}

\begin{document}

\START

\TEST{default period width}{
  \setbox0=\hbox{еӯ—гҖӮеӯ—}
  \setbox2=\hbox{еӯ—}
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd2
  \TYPE{period-context-width:~\the\dimen0}
}

\TEST{custom comma width via xeCJKsetwidth}{
  \setbox0=\hbox{еӯ—пјҢеӯ—}
  \setbox2=\hbox{еӯ—}
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd2
  \TYPE{comma-context-width:~\the\dimen0}
}

\TEST{custom kern via xeCJKsetkern}{
  \setbox0=\hbox{еӯ—пјҢгҖӮеӯ—}
  \TYPE{comma-period-width:~\the\wd0}
}

\END

