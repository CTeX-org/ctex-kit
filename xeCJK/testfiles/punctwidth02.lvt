\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\xeCJKsetwidth{。？}{0.7em}
\xeCJKsetkern{：}{「}{0.3em}

\begin{document}

\START

\TEST{xeCJKsetwidth multiple puncts}{
  \setbox0=\hbox{字。字}
  \setbox1=\hbox{字？字}
  \TYPE{period-width:~\the\wd0}
  \TYPE{question-width:~\the\wd1}
}

\TEST{xeCJKsetkern colon quote}{
  \setbox0=\hbox{字：「字」}
  \TYPE{colon-quote:~\the\wd0}
}

\END

\end{document}
