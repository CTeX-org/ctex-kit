\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}
\setCJKsansfont{FandolHei-Regular.otf}
\setCJKmonofont{FandolKai-Regular.otf}

\begin{document}

\START

\TEST{CJKfamily plus switches to sans}{
  \setbox0=\hbox{{\CJKfamily+字}}
  \TYPE{plus: \the\wd0}
  \setbox1=\hbox{{\sffamily 字}}
  \TYPE{sffamily: \the\wd1}
}

\TEST{CJKfamily minus switches to mono}{
  \setbox0=\hbox{{\sffamily\CJKfamily-字}}
  \TYPE{minus-from-sf: \the\wd0}
  \setbox1=\hbox{{\rmfamily 字}}
  \TYPE{rmfamily: \the\wd1}
}

\TEST{CJKfamily explicit name}{
  \setCJKfamilyfont{kai}{FandolKai-Regular.otf}
  \setbox0=\hbox{{\CJKfamily{kai}字}}
  \TYPE{kai: \the\wd0}
}

\END

\end{document}
