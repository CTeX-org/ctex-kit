\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\setbox0=\hbox{\xeCJKchar"00B7}
\setbox1=\hbox{·}

\edef\widthXeCJKchar{\the\wd0}
\edef\widthText{\the\wd1}

\TEST{xeCJKchar~bypasses~interchar~for~middle~dot}{
  \TYPE{xeCJKchar~=~\widthXeCJKchar}
  \TYPE{text~=~\widthText}
  \ifdim\wd0=\wd1
    \TYPE{FAIL:~xeCJKchar~used~CJK~font}
  \else
    \TYPE{PASS}
  \fi
}

\setbox2=\hbox{$\vcenter{\hbox{\xeCJKchar"00B7}}$}
\setbox3=\hbox{$\vcenter{\hbox{·}}$}

\edef\widthMathXeCJKchar{\the\wd2}
\edef\widthMathText{\the\wd3}

\TEST{xeCJKchar~in~math~hbox~bypasses~interchar}{
  \TYPE{math-hbox-xeCJKchar~=~\widthMathXeCJKchar}
  \TYPE{math-hbox-text~=~\widthMathText}
  \ifdim\wd2=\wd3
    \TYPE{FAIL:~xeCJKchar~used~CJK~font~in~math~hbox}
  \else
    \TYPE{PASS}
  \fi
}

\setbox4=\hbox{\char"00B7}
\setbox5=\hbox{·}

\TEST{bare~char~still~triggers~interchar}{
  \TYPE{char~=~\the\wd4}
  \TYPE{text~=~\the\wd5}
  \ifdim\wd4=\wd5
    \TYPE{PASS:~char~and~text~use~same~font}
  \else
    \TYPE{FAIL:~char~bypassed~interchar}
  \fi
}

\END

\end{document}
