\input{regression-test}

\documentclass{article}

\usepackage[AutoFallBack]{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}
\setCJKfallbackfamilyfont{\CJKrmdefault}{FandolKai-Regular.otf}

\begin{document}

\START

\TEST{fallback font loaded}{
  \setbox0=\hbox{字}
  \TYPE{main-font:~\the\wd0}
}

\TEST{AutoFallBack false disables fallback}{
  \xeCJKsetup{AutoFallBack=false}
  \setbox0=\hbox{字}
  \TYPE{no-fallback:~\the\wd0}
  \xeCJKsetup{AutoFallBack=true}
}

\END

\end{document}
