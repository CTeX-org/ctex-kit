\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{footnote with CJK}{
  \setbox0=\vbox{%
    字字字\footnote{脚注内容}字字字
    \vfil
  }
  \TYPE{footnote-vbox:~\the\ht0}
}

\TEST{xeCJKnobreak before footnote}{
  \setbox0=\hbox{字。\xeCJKnobreak\footnotemark}
  \TYPE{nobreak-footnote:~\the\wd0}
}

\END

\end{document}
