\input{regression-test}

\documentclass{article}

\usepackage{xeCJK,xeCJKfntef}
\setCJKmainfont[BoldFont=FandolHei-Regular.otf]{FandolSong-Regular.otf}
\setCJKsansfont{FandolKai-Regular.otf}

\showboxdepth=5
\showboxbreadth=100

\begin{document}

\START

\OMIT
\ExplSyntaxOn
\setbox0=\hbox{ \CJKunderdot{文字{\bfseries 文字}} ~ \CJKunderdot{文字} }
\setbox2=\hbox{ 文字{\bfseries 文字} ~ 文字 }
\ExplSyntaxOff
\TIMO

\TEST{underdot~intergroup~space~matches~plain~text}{
  \typeout{underdot~ width:~ \the\wd0}
  \typeout{plain~ width:~ \the\wd2}
  \ifdim\wd0=\wd2
    \typeout{PASS:~ widths~ match}
  \else
    \typeout{FAIL:~ widths~ differ}
  \fi
  \showbox0
}

\END

\end{document}
