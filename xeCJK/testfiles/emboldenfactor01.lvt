\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{default EmboldenFactor}{
  \setCJKfamilyfont{testbold}{FandolSong-Regular.otf}[AutoFakeBold]
  \setbox0=\hbox{{\CJKfamily{testbold}\bfseries 字}}
  \TYPE{default-factor: \the\wd0}
}

\TEST{custom EmboldenFactor}{
  \xeCJKsetemboldenfactor{6}
  \setCJKfamilyfont{testbold2}{FandolSong-Regular.otf}[AutoFakeBold]
  \setbox0=\hbox{{\CJKfamily{testbold2}\bfseries 字}}
  \TYPE{embolden-6: \the\wd0}
}

\TEST{custom SlantFactor}{
  \xeCJKsetslantfactor{0.3}
  \setCJKfamilyfont{testslant}{FandolSong-Regular.otf}[AutoFakeSlant]
  \setbox0=\hbox{{\CJKfamily{testslant}\itshape 字}}
  \TYPE{slant-0.3: \the\wd0}
}

\END

\end{document}
