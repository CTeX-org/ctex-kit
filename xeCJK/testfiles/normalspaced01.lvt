\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{CJK char default has CJKglue}{
  \setbox0=\hbox{字字}
  \setbox2=\hbox{字}
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd2
  \TYPE{CJK-CJK-glue: \the\dimen0}
}

\TEST{normalspacedchars on CJK removes interchar}{
  \normalspacedchars{字}
  \setbox0=\hbox{国字国}
  \setbox2=\hbox{国}
  \setbox3=\hbox{字}
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd3
  \TYPE{normalspaced-glue: \the\dimen0}
}

\TEST{other CJK chars still have interchar}{
  \setbox0=\hbox{国A国}
  \setbox2=\hbox{国}
  \setbox3=\hbox{A}
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd3
  \TYPE{ecglue-still-present: \the\dimen0}
}

\END

\end{document}
