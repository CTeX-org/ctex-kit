% ========== color wraps fntef (informational) ==========
% Document the current behavior of textcolor wrapping fntef commands.

\TEST{textcolor~wrapping~fntef~current~behavior}{
  \setbox0=\hbox{前 \CJKunderdot{中} 后}
  \setbox2=\hbox{前 \textcolor{red}{\CJKunderdot{中}} 后}
  \typeout{CJKunderdot:~\the\wd0\space vs~\the\wd2}
  \setbox0=\hbox{前 \CJKunderline{中} 后}
  \setbox2=\hbox{前 \textcolor{red}{\CJKunderline{中}} 后}
  \typeout{CJKunderline:~\the\wd0\space vs~\the\wd2}
  \setbox0=\hbox{前 \CJKsout{中} 后}
  \setbox2=\hbox{前 \textcolor{red}{\CJKsout{中}} 后}
  \typeout{CJKsout:~\the\wd0\space vs~\the\wd2}
}

\END

