\TEST{multi-char~CJKunderdot~wrapping~textcolor~same~width}{
  \setbox0=\hbox{前 \CJKunderdot{虚室生白} 后}
  \setbox2=\hbox{前 \CJKunderdot{\textcolor{red}{虚室生白}} 后}
  \ifdim\wd0=\wd2
    \TYPE{PASS:~\the\wd0}
