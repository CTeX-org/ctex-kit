\input{regression-test}

\documentclass{article}

\usepackage{xeCJK,xeCJKfntef}
\usepackage{xcolor}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

% ========== fntef wraps color (recommended usage) ==========

\TEST{CJKunderdot~wrapping~textcolor~same~width}{
  \setbox0=\hbox{前 \CJKunderdot{中} 后}
  \setbox2=\hbox{前 \CJKunderdot{\textcolor{red}{中}} 后}
  \ifdim\wd0=\wd2
    \TYPE{PASS:~\the\wd0}
  \else
    \TYPE{FAIL:~\the\wd0\space vs~\the\wd2}
  \fi
}

\TEST{CJKunderline~wrapping~textcolor~same~width}{
  \setbox0=\hbox{前 \CJKunderline{中} 后}
  \setbox2=\hbox{前 \CJKunderline{\textcolor{red}{中}} 后}
  \ifdim\wd0=\wd2
    \TYPE{PASS:~\the\wd0}
  \else
    \TYPE{FAIL:~\the\wd0\space vs~\the\wd2}
  \fi
}

