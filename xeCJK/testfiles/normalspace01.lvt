\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{space between Latin words preserved}{
  \setbox0=\hbox{hello world}
  \setbox1=\hbox{helloworld}
  \ifdim\wd0=\wd1
    \TYPE{FAIL: space lost}
  \else
    \TYPE{PASS: space preserved}
  \fi
}

\TEST{space between CJK and Latin}{
  \setbox0=\hbox{字abc}
  \setbox1=\hbox{字 abc}
  \TYPE{no-space: \the\wd0}
  \TYPE{with-space: \the\wd1}
}

\TEST{multiple spaces between CJK collapsed}{
  \setbox0=\hbox{字 字}
  \setbox1=\hbox{字  字}
  \ifdim\wd0=\wd1
    \TYPE{PASS: multiple spaces collapsed}
  \else
    \TYPE{FAIL: \the\wd0\space vs \the\wd1}
  \fi
}

\TEST{tilde produces nobreak space between Latin}{
  \setbox0=\hbox{A~B}
  \setbox1=\hbox{A B}
  \TYPE{tilde: \the\wd0}
  \TYPE{space: \the\wd1}
}

\END

\end{document}
