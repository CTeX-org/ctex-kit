\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

\TEST{xeCJKchar bypasses interchar}{
  \setbox0=\hbox{\xeCJKchar"4E00\relax}
  \setbox1=\hbox{一}
  \TYPE{xeCJKchar:~\the\wd0}
  \TYPE{direct:~\the\wd1}
}

\TEST{xeCJKchar in Latin context no ecglue}{
  \setbox0=\hbox{A\xeCJKchar"4E00\relax B}
  \setbox1=\hbox{A一B}
  \TYPE{xeCJKchar-ctx:~\the\wd0}
  \TYPE{direct-ctx:~\the\wd1}
}

\END

\end{document}
