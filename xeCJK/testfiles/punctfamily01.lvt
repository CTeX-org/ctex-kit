\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}
\setCJKfamilyfont{kaiti}{FandolKai-Regular.otf}

\begin{document}

\START

\TEST{default punct uses main font}{
  \setbox0=\hbox{字}
  \setbox1=\hbox{，}
  \TYPE{text:~\the\wd0}
  \TYPE{punct:~\the\wd1}
}

\TEST{PunctFamily changes punct font}{
  \xeCJKsetup{PunctFamily=kaiti}
  \setbox0=\hbox{字}
  \setbox1=\hbox{，}
  \TYPE{text:~\the\wd0}
  \TYPE{punct-kaiti:~\the\wd1}
}

\TEST{PunctFamily=false restores default}{
  \xeCJKsetup{PunctFamily=false}
  \setbox0=\hbox{字}
  \setbox1=\hbox{，}
  \TYPE{text:~\the\wd0}
  \TYPE{punct-restored:~\the\wd1}
}

\END

\end{document}
