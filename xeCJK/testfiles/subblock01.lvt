}

\TEST{SubCJKBlock with different font}{
  \setCJKfamilyfont{Ext-A}[AutoFakeBold]{FandolSong-Regular.otf}
  \setbox0=\hbox{字}
  \TYPE{basic: \the\wd0}
}

\END

