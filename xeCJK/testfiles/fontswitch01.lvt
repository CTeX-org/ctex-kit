\input{regression-test}

\documentclass{article}

\usepackage{xeCJK}
\setCJKmainfont{FandolSong-Regular.otf}

\begin{document}

\START

% Measure front-side ecglue by subtracting glyph widths
\def\measureecglue#1#2{%
  \setbox0=\hbox{字#1{A}\kern0pt}%
  \setbox2=\hbox{字}%
  \setbox3=\hbox{#1{A}}%
  \dimen0=\wd0 \advance\dimen0 by -\wd2 \advance\dimen0 by -\wd3
  \TYPE{#2 front ecglue = \the\dimen0}%
}

\TEST{CJKecglue~not~affected~by~\texttt}{
  \measureecglue{\relax}{baseline}
  \measureecglue{\texttt}{texttt}
}

\TEST{CJKecglue~not~affected~by~\textbf}{
  \measureecglue{\relax}{baseline}
  \measureecglue{\textbf}{textbf}
}

\TEST{CJKecglue~not~affected~by~\textit}{
  \measureecglue{\relax}{baseline}
  \measureecglue{\textit}{textit}
}

\newcommand\sizesmall[1]{{\small #1}}

\TEST{CJKecglue~not~affected~by~font~size~change}{
  \measureecglue{\relax}{baseline}
  \measureecglue{\sizesmall}{small}
}

\END

\end{document}
