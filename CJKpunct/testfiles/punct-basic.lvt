\input{regression-test}

\documentclass{article}

\OMIT
\usepackage{CJKutf8}
\usepackage{CJKspace}
\usepackage{CJKpunct}
\TIMO

\begin{document}

\START

\begin{CJK*}{UTF8}{gbsn}

\ExplSyntaxOn

\TEST{CJKpunct~loads~with~quanjiao~style}{
  \TYPE { punctstyle:~ \use:c { CJKpunct@punctstyle } }
}

\TEST{Opening~punct~width~in~hbox}{
  \hbox_set:Nn \l_tmpa_box { （ }
  \bool_set:Nn \l_tmpa_bool { \dim_compare_p:nNn { \box_wd:N \l_tmpa_box } > { 0pt } }
  \TYPE { has-width:~ \bool_if:NTF \l_tmpa_bool { yes } { no } }
}

\TEST{Closing~punct~width~in~hbox}{
  \hbox_set:Nn \l_tmpa_box { ） }
  \bool_set:Nn \l_tmpa_bool { \dim_compare_p:nNn { \box_wd:N \l_tmpa_box } > { 0pt } }
  \TYPE { has-width:~ \bool_if:NTF \l_tmpa_bool { yes } { no } }
}

\TEST{CJK~text~with~punctuation~in~hbox}{
  \hbox_set:Nn \l_tmpa_box { 测试（括号）文本 }
  \bool_set:Nn \l_tmpa_bool { \dim_compare_p:nNn { \box_wd:N \l_tmpa_box } > { 0pt } }
  \TYPE { has-width:~ \bool_if:NTF \l_tmpa_bool { yes } { no } }
}

\TEST{Switching~punctstyle~to~banjiao}{
  \group_begin:
  \punctstyle { banjiao }
  \TYPE { punctstyle:~ \use:c { CJKpunct@punctstyle } }
  \group_end:
}

\TEST{Switching~punctstyle~to~kaiming}{
  \group_begin:
  \punctstyle { kaiming }
  \TYPE { punctstyle:~ \use:c { CJKpunct@punctstyle } }
  \group_end:
}

\ExplSyntaxOff

\end{CJK*}

\END

\end{document}
