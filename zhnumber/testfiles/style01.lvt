\input{regression-test}

\documentclass{article}
\usepackage{zhnumber}

\START

\ExplSyntaxOn

\TEST{style~=~Normal}{
  \group_begin:
    \zhnumsetup { style = Normal }
    \clist_map_inline:nn
      { 1, 10, 100, 1000, 10000, 12345 }
      { \tl_log:x { \zhnumber {#1} } }
  \group_end:
}

\TEST{style~=~Financial}{
  \group_begin:
    \zhnumsetup { style = Financial }
    \clist_map_inline:nn
      { 1, 10, 100, 1000, 10000, 12345 }
      { \tl_log:x { \zhnumber {#1} } }
  \group_end:
}

\ExplSyntaxOff

\END

\end{document}
