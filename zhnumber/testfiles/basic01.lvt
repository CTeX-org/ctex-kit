\input{regression-test}

\documentclass{article}
\usepackage{zhnumber}

\START

\ExplSyntaxOn

\TEST{\zhnumber:~basic~integers}{
  \clist_map_inline:nn
    { 0, 1, 2, 10, 100, 1000, 10000, 1000000, 2020020200 }
    { \tl_log:x { \zhnumber {#1} } }
}

\TEST{\zhnumber:~decimals~and~signs}{
  \clist_map_inline:nn
    { 1.2, 2020.020200, 2020., .2020, -2020, +2020 }
    { \tl_log:x { \zhnumber {#1} } }
}

\TEST{\zhnumber:~fractions}{
  \clist_map_inline:nn
    { 2020/2019, /2020, 2020/, 2020/2/2 }
    { \tl_log:x { \zhnumber {#1} } }
}

\TEST{\zhdigits:~basic}{
  \clist_map_inline:nn
    { 0, 1, 100, 1.2, 2020020200 }
    { \tl_log:x { \zhdigits {#1} } }
}

\ExplSyntaxOff

\END

\end{document}
