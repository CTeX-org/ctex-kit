\documentclass{article}
\usepackage{zhnumber}

\START

\ExplSyntaxOn

\TEST{deprecation~safe:~\zhnumber}{
  \clist_map_inline:nn
    { 0, 1, 100, 12345, 1.2, -2020 }
    { \tl_log:x { \zhnumber {#1} } }
}

\TEST{deprecation~safe:~\zhdigits}{
  \clist_map_inline:nn
    { 0, 1, 100, 12345 }
    { \tl_log:x { \zhdigits {#1} } }
}

\ExplSyntaxOff

\END

