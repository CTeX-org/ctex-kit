%       \vdots & \vdots &        & \vdots \\
%       a_{m1} & a_{m2} & \dotsc & a_{mn}
%     \end{originalpmatrix},
%   \]
%   其中 $a_{ij} \in \symbb R$, $i = 1$, $\dotsc\,$,~$m$,
%   $j = 1$, $\dotsc\,$,~$n$. 又因为
