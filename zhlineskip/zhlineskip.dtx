\AtEndOfPackage
  {
    \bool_lazy_or:nnF
      { \g_@@_MSWordLineSpacingMultiple_bool                                 }
      { \fp_compare_p:nNn { \g_@@_MSWordSinglespaceRatio_fp } = { 1.296875 } }
      {
        \@@_msg_warning:nnn { Ineffective ~ Option } { MSWordSinglespaceRatio }
          { MSWordLineSpacingMultiple ~ = ~ true }
      }
  }
