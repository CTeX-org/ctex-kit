%   我们得到……
% }
% \long \def \1{^^A
%   设 $\symbf I_2 =
%     \begin{psmallmatrix}
%       1 & 0 \\
%       0 & 1
%     \end{psmallmatrix}$.
%   又设 $\symbf A = (a_{ij})_{m \times n}$ 为一个 $m$~行
%   $n$~列的实值矩阵, 即
%   \[
%     \symbf A =
%     \begin{pmatrix}
%       a_{11} & a_{12} & \dotsc & a_{1n} \\
%       a_{21} & a_{22} & \dotsc & a_{2n} \\
%       \vdots & \vdots &        & \vdots \\
%       a_{m1} & a_{m2} & \dotsc & a_{mn}
%     \end{pmatrix},
