\patchcmd \__codedoc_codemo_end:Nn
  { \parbox [ c ] [ \l__codedoc_codemo_int \baselineskip + .48ex ] }
  { \parbox [ c ] [ 16 \baselineskip + .48ex ] [ t ] }
  { } { }
\patchcmd \__codedoc_codemo_end:Nn
  { \parbox [ c ] [ \l__codedoc_codemo_int \baselineskip + .48ex ] }
  { \parbox [ c ] [ 16 \baselineskip + .48ex ] [ t ] }
  { } { }
\setlength \ttwd {0pt}
