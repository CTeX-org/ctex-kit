\input{regression-test}

\documentclass{article}

\OMIT
\usepackage[bodytextleadingratio=2]{zhlineskip}
\usepackage{amsmath}
\TIMO

\ExplSyntaxOn

\START

\begin{document}

\TEST{Body~baselineskip~scaled~by~leading~ratio}{
  \TYPE{baselineskip=\the\baselineskip}
  \TYPE{baselinestretch=\baselinestretch}
}

\TEST{Gather~display~with~restored~leading}{
  \setcounter{equation}{0}
  \vbox_set:Nn \l_tmpa_box {
    X \par
    \begin{gather}
      a = b + c \\
      d = e + f
    \end{gather}
    X \par
  }
  \TYPE{gather~ht=\dim_eval:n{\box_ht:N \l_tmpa_box}}
  \TYPE{gather~dp=\dim_eval:n{\box_dp:N \l_tmpa_box}}
}

\TEST{Align~display~with~restored~leading}{
  \setcounter{equation}{0}
  \vbox_set:Nn \l_tmpa_box {
    X \par
    \begin{align}
      a &= b + c \\
      d &= e + f
    \end{align}
    X \par
  }
  \TYPE{align~ht=\dim_eval:n{\box_ht:N \l_tmpa_box}}
  \TYPE{align~dp=\dim_eval:n{\box_dp:N \l_tmpa_box}}
}

\TEST{Multline~display~with~restored~leading}{
  \setcounter{equation}{0}
  \vbox_set:Nn \l_tmpa_box {
    X \par
    \begin{multline}
      a = b + c + d + e + f \\
      + g + h + i + j
    \end{multline}
    X \par
  }
  \TYPE{multline~ht=\dim_eval:n{\box_ht:N \l_tmpa_box}}
  \TYPE{multline~dp=\dim_eval:n{\box_dp:N \l_tmpa_box}}
}

\ExplSyntaxOff

\END

\end{document}
