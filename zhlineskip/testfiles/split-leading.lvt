\input{regression-test}

\documentclass{article}

\OMIT
\usepackage[bodytextleadingratio=2]{zhlineskip}
\usepackage{amsmath}
\TIMO

\ExplSyntaxOn

\START

\begin{document}

\TEST{Multi-line~split~display~spacing~(github~\#735)}{
  \setcounter{equation}{0}
  \vbox_set:Nn \l_tmpa_box {
    X \par
    \begin{equation}
      \begin{split}
        a &= b + c \\
        &= d + e
      \end{split}
    \end{equation}
    X \par
  }
  \TYPE{split~ht=\dim_eval:n{\box_ht:N \l_tmpa_box}}
  \TYPE{split~dp=\dim_eval:n{\box_dp:N \l_tmpa_box}}
}

\TEST{Single-line~split~display~spacing~(\#735)}{
  \setcounter{equation}{0}
  \vbox_set:Nn \l_tmpa_box {
    X \par
    \begin{equation}
      \begin{split}
        a = b
      \end{split}
    \end{equation}
    X \par
  }
  \TYPE{single-split~ht=\dim_eval:n{\box_ht:N \l_tmpa_box}}
  \TYPE{single-split~dp=\dim_eval:n{\box_dp:N \l_tmpa_box}}
}

\TEST{Split~with~tag}{
  \setcounter{equation}{0}
  \vbox_set:Nn \l_tmpa_box {
    X \par
    \begin{equation}
      \begin{split}
        f(x) &= a + b \\
        &= c + d
      \end{split}
      \tag{$\star$}
    \end{equation}
    X \par
  }
  \TYPE{split-tag~ht=\dim_eval:n{\box_ht:N \l_tmpa_box}}
  \TYPE{split-tag~dp=\dim_eval:n{\box_dp:N \l_tmpa_box}}
}

\ExplSyntaxOff

\END

\end{document}
