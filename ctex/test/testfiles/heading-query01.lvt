\input{regression-test}

\documentclass[fontset=fandol]{ctexbeamer}

\ctexset
  {
    part =
      {
        name = {P(,)},
        number = \Roman{part},
        nameformat = \bfseries,
        numberformat = \itshape
      },
    section =
      {
        name = {S(,)},
        number = \Alph{section},
        nameformat = \bfseries,
        numberformat = \itshape
      },
    subsection =
      {
        name = {SS(,)},
        number = \arabic{section}.\arabic{subsection},
        nameformat = \bfseries,
        numberformat = \itshape
      }
  }

\setcounter{part}{2}
\setcounter{section}{3}
\setcounter{subsection}{4}

\begin{document}

\START

\AUTHOR{Liam Huang}

\ExplSyntaxOn
\cs_new_protected:Npn \test_heading_query:n #1
  {
    \iow_term:e { number/#1=[\CTEXheadingnumber{#1}] }
    \iow_term:e { label/#1=[\CTEXheadinglabel{#1}] }
    \iow_term:e
      {
        numbering/#1=
          [\CTEXifheadingnumbering{#1}{true}{false}]
      }
  }

\TEST { heading~queries }
  {
    \test_heading_query:n { part }
    \test_heading_query:n { section }
    \test_heading_query:n { subsection }
  }

\TEST { dynamic~and~local~settings }
  {
    \group_begin:
      \ctexset
        {
          section =
            {
              name = {Local(,)},
              number = \roman{section},
              numbering = false
            }
        }
      \test_heading_query:n { section }
    \group_end:
    \test_heading_query:n { section }
  }
\ExplSyntaxOff

\END

\end{document}
