\ExplSyntaxOn
\sys_if_engine_pdftex:T
  {
    \ExplSyntaxOff
    \input { regression-test }
    \START \TYPE { pdfTeX:~CJKecglue~not~supported. } \END
    \stop
  }
\ExplSyntaxOff

\input{regression-test}

\documentclass[fontset=fandol]{ctexart}

\begin{document}

\START

\ExplSyntaxOn

\TEST { experiment/CJKecglue~set~value }
  {
    \ctexset { experiment/CJKecglue = 5pt~plus~2pt~minus~1pt }
    \sys_if_engine_xetex:T
      { \skip_log:n { \l__xeCJK_ecglue_skip } }
    \sys_if_engine_luatex:T
      { \skip_log:n { \ltjgetparameter { xkanjiskip } } }
    \sys_if_engine_uptex:T
      { \skip_log:n { \tex_xkanjiskip:D } }
  }

\TEST { experiment/CJKecglue~group~scope }
  {
    \group_begin:
      \ctexset { experiment/CJKecglue = 10pt }
      \sys_if_engine_xetex:T
        { \skip_log:n { \l__xeCJK_ecglue_skip } }
      \sys_if_engine_luatex:T
        { \skip_log:n { \ltjgetparameter { xkanjiskip } } }
      \sys_if_engine_uptex:T
        { \skip_log:n { \tex_xkanjiskip:D } }
    \group_end:
    \sys_if_engine_xetex:T
      { \skip_log:n { \l__xeCJK_ecglue_skip } }
    \sys_if_engine_luatex:T
      { \skip_log:n { \ltjgetparameter { xkanjiskip } } }
    \sys_if_engine_uptex:T
      { \skip_log:n { \tex_xkanjiskip:D } }
  }

\ExplSyntaxOff

\END

