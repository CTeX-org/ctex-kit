\input{regression-test}

\documentclass[fontset=fandol]{ctexart}

\begin{document}

\START

\AUTHOR{Liam Huang}

\loggingoutput

\TEST{default section with centering}{
  \section{居中节标题}
  文字文字文字文字文字文字文字文字文字文字文字文字文字文字文字文字
  \clearpage
}

\TEST{section raggedright}{
  \ctexset{section/format = \Large\bfseries\raggedright}
  \section{左对齐节标题}
  文字文字文字文字文字文字文字文字文字文字文字文字文字文字文字文字
  \clearpage
}

\TEST{subsection with rule before}{
  \ctexset{subsection/format = \normalfont\large\bfseries,
           subsection/break = \noindent\rule{\linewidth}{0.4pt}\par}
  \subsection{带横线的小节}
  文字
  \clearpage
}

\TEST{section long title hang}{
  \ctexset{section/hang = true}
  \section{这是一个很长很长很长很长很长很长很长很长的中文节标题用来测试悬挂效果}
  文字
  \clearpage
}

\END

\end{document}
