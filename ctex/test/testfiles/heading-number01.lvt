  \ctexset{section/number = \chinese{section}}
  \section{中文节编号}
  文字
  \clearpage
}

\TEST{section number Roman}{
  \ctexset{section/number = \Roman{section}}
  \section{罗马数字节}
  文字
  \clearpage
}

\END

