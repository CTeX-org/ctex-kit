  \clearpage
}

\TEST{subsection indent with hang false}{
  \ctexset{
    subsection/indent = 1em,
    subsection/hang = false
  }
  \subsection{缩进不悬挂的小节标题，标题很长很长很长很长很长很长很长很长}
  文字
  \clearpage
}

