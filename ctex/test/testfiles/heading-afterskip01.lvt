\documentclass[fontset=fandol]{ctexart}

\begin{document}

\START

\AUTHOR{Liam Huang}

\TEST{section afterskip positive}{
  \ctexset{section/afterskip = 2.3ex plus .2ex}
  \loggingoutput
  \section{正afterskip}
  后续段落。
  \clearpage
}

\TEST{section afterskip negative runin}{
  \ctexset{
    section/runin = true,
    section/afterskip = 1em,
  }
  \section{runin标题}
  紧跟的文字。
  \clearpage
}

\TEST{subsection afterskip custom}{
  \ctexset{subsection/afterskip = 1ex}
  \subsection{自定义间距}
  后续段落。
  \clearpage
}

\END

\end{document}
