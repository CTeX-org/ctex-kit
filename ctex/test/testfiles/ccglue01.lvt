\TEST{CJKglue~set~in~preamble~preserved~after~\begin}{
  \cs_log:N \CJKglue
}

\TEST{CJKglue~set~in~body~preserved}{
  \group_begin:
    \sys_if_engine_xetex:T
      { \xeCJKsetup { CJKglue = { \hskip 0.5em plus 0.02em minus 0.02em } } }
    \sys_if_engine_pdftex:T
      { \cs_set_protected:Npn \CJKglue { \hskip 0.5em plus 0.02em minus 0.02em } }
    \cs_log:N \CJKglue
  \group_end:
}

\TEST{CJKglue~restored~after~group}{
  \cs_log:N \CJKglue
}

