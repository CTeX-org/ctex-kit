\TEST{appendix default numbering}{
  \appendix
  \chapter{附录默认}
  文字
  \section{附录节}
  文字
  \clearpage
}

\TEST{appendix numbering false}{
  \ctexset{appendix/numbering = false}
  \chapter{附录无编号}
  文字
  \clearpage
}

\TEST{appendix custom name}{
  \ctexset{
    appendix/numbering = true,
    appendix/name = {附录},
    appendix/number = \Alph{chapter}
  }
  \chapter{自定义附录名}
  文字
  \clearpage
}

\END

