\input{regression-test}

\documentclass[fontset=fandol]{ctexart}

\begin{document}

\START

\AUTHOR{Liam Huang}

\TEST{negative beforeskip suppresses afterindent}{
  \ctexset{section/beforeskip = -3.5ex plus -1ex minus -.2ex}
  \loggingoutput
  \section{负beforeskip的节}
  首段文字（不应缩进）。
  \clearpage
}

\TEST{positive beforeskip keeps afterindent}{
  \ctexset{
    section/beforeskip = 3.5ex plus 1ex minus .2ex,
    section/afterindent = true,
  }
  \section{正beforeskip的节}
  首段文字（应缩进）。
  \clearpage
}

\END

\end{document}
