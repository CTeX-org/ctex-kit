\TEST{footnote basic}{
  正文内容\footnote{这是一条脚注。}。
  \clearpage
}

\TEST{footnote multiple}{
  第一句\footnote{脚注一}。第二句\footnote{脚注二}。第三句\footnote{脚注三}。
  \clearpage
}

\TEST{footnote in section}{
  \section{带脚注的标题\footnote{标题中的脚注}}
  正文。
  \clearpage
}

\END

