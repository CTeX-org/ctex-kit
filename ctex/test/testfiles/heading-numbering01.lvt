\input{regression-test}

\documentclass[fontset=fandol]{ctexbook}

\begin{document}

\START

\AUTHOR{Liam Huang}

\loggingoutput

\TEST{default chapter numbering}{
  \chapter{默认编号}
  文字
  \clearpage
}

\TEST{section numbering false}{
  \ctexset{section/numbering = false}
  \section{无编号节}
  文字
  \section{无编号节二}
  文字
  \clearpage
}

\TEST{chapter number arabic}{
  \ctexset{chapter/number = \arabic{chapter}}
  \chapter{阿拉伯数字章}
  文字
  \clearpage
}

\END

\end{document}
