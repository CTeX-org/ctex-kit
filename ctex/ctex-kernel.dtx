% 区分 \tn{AtEndOfClass} 和 \tn{AtEndOfPackage}，虽然它们的意思都是一样的。
%    \begin{macrocode}
%<class>\cs_new_protected:Npn \ctex_at_end:n { \AtEndOfClass }
%<ctex>\cs_new_protected:Npn \ctex_at_end:n { \AtEndOfPackage }
