\ProvidesExplFile{ctex-fontset-kai-demo.def}
  {2026/07/15}{0.1}{Local upLaTeX fontset demonstration}

\ExplSyntaxOn
% 当前 ctex 的 upTeX 后端使用六个既有 JFM/VF 角色。这里仅替换其 dvipdfmx 映射。
\ctex_set_upfonts:nnnnnn
  { FandolKai-Regular.otf  } % serif regular
  { FandolSong-Bold.otf    } % serif bold
  { FandolKai-Regular.otf  } % serif italic
  { FandolHei-Regular.otf  } % sans regular
  { FandolHei-Bold.otf     } % sans bold
  { FandolFang-Regular.otf } % mono regular

\ctex_set_upfamily:nnn { zhsong } { upzhserif   } { upzhserifb }
\ctex_set_upfamily:nnn { zhhei  } { upzhsans    } { upzhsansb  }
\ctex_set_upfamily:nnn { zhfs   } { upzhmono    } { }
\ctex_set_upfamily:nnn { zhkai  } { upzhserifit } { }
\ExplSyntaxOff
